        "uncertain_fields_include": ["notes"]
      },
      "expected_note_items": [
        {
          "raw_line_text": "318 RWM",
          "parsed_ear_label_review_status": "needs_review"
        },
        {
          "raw_line_text": "319 L'",
          "parsed_ear_label_code": "L_PRIME",
          "parsed_ear_label_review_status": "auto_filled"
        },
        {
          "raw_line_text": "320 R'L'",
          "parsed_ear_label_code": "R_PRIME_L_PRIME",
          "parsed_ear_label_review_status": "auto_filled"
        }
      ],
      "expected_open_review": {
        "attention_levels_include": ["quick_check"],
        "targets_include": ["Ear label", "Source photo"]
      }
    },
