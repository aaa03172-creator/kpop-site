      "case_id": "rwm_impossible_ear_label",
      "photo_id": "photo_45193d422a8f",
      "photo_filename": "KakaoTalk_20260502_102059315_09.jpg",
      "purpose": "A W-like struck note must remain reviewable instead of being accepted as a clean ear label.",
      "min_photo_bytes": 100000,
      "expected_parse": {
        "status": "review",
        "min_confidence": 40,
        "field_contains": {
          "rawStrain": ["ApoM", "Tg/Tg"],
          "mouseCount": ["2"]
